  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:report": "npx playwright show-report",
    "vrt:update": "npx playwright test tests/visual.spec.ts --update-snapshots --project=chromium",
    "vrt:run": "npx playwright test tests/visual.spec.ts --project=chromium",
    "vrt:run:all-browsers": "npx playwright test tests/visual.spec.ts",
    "vrt:update:all-browsers": "npx playwright test tests/visual.spec.ts --update-snapshots",
    "perf:run": "npx playwright test tests/performance.spec.ts --project=chromium --workers=1 --timeout=120000"
  },
